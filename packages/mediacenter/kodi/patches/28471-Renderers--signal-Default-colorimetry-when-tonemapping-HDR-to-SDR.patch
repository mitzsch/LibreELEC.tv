From 09d1ff3a7adb2197ad8d099b45f4a3be235fff05 Mon Sep 17 00:00:00 2001
From: reardonia <2925104+reardonia@users.noreply.github.com>
Date: Sat, 20 Jun 2026 07:22:09 -0400
Subject: [PATCH] Renderers: signal Default colorimetry when tonemapping HDR to
 SDR

When CheckVideoParameters detects m_toneMap flipping due to a state
change (first frame after Configure, or user toggling the tonemap
method in the OSD), push the matching colorimetry to the connector:

  - tonemap-to-SDR active: AVCOL_SPC_UNSPECIFIED so the connector
    falls through to the Default tag, signaling BT.709 RGB at HD
    resolutions per CTA-861.
  - tonemap-to-SDR inactive: revert to the source colorimetry held
    on the current buffer.

Configure's existing SetColorimetry(&picture) call still runs first
and handles non-tonemap content; this only overrides on the transition.

Without this fix, HDR PQ content tonemapped via Reinhard / ACES / Hable
to SDR was being signaled as BT.2020_RGB on HDMI while the wire pixels
were BT.709 RGB. The sink applied BT.2020 -> display gamut mapping to
already-BT.709 pixels, producing oversaturated output.

Affects every renderer that inherits CLinuxRendererGL / GLES: software,
VAAPI, VideoToolbox.

Tagged with a //! @todo for proper cleanup in Piers beta 2.

Reported-by: HiassofT
Fixes: #28468
---
 .../VideoPlayer/VideoRenderers/LinuxRendererGL.cpp    | 11 +++++++++++
 .../VideoPlayer/VideoRenderers/LinuxRendererGLES.cpp  | 11 +++++++++++
 2 files changed, 22 insertions(+)

diff --git a/xbmc/cores/VideoPlayer/VideoRenderers/LinuxRendererGL.cpp b/xbmc/cores/VideoPlayer/VideoRenderers/LinuxRendererGL.cpp
index 3d5436545e062..59876b7b29d8a 100644
--- a/xbmc/cores/VideoPlayer/VideoRenderers/LinuxRendererGL.cpp
+++ b/xbmc/cores/VideoPlayer/VideoRenderers/LinuxRendererGL.cpp
@@ -2823,6 +2823,17 @@ void CLinuxRendererGL::CheckVideoParameters(int index)
   if (toneMap != m_toneMap || toneMapMethod != m_toneMapMethod)
   {
     m_reloadShaders = true;
+
+    //! @todo HACK for #28468; clean up properly in Piers beta 2
+    if (toneMap != m_toneMap)
+    {
+      VideoPicture tmp{};
+      tmp.color_space = toneMap ? AVCOL_SPC_UNSPECIFIED : buf.m_srcColSpace;
+      tmp.iWidth = m_sourceWidth;
+      tmp.iHeight = m_sourceHeight;
+      CServiceBroker::GetWinSystem()->SetColorimetry(&tmp);
+    }
+
     m_toneMap = toneMap;
     m_toneMapMethod = toneMapMethod;
   }
diff --git a/xbmc/cores/VideoPlayer/VideoRenderers/LinuxRendererGLES.cpp b/xbmc/cores/VideoPlayer/VideoRenderers/LinuxRendererGLES.cpp
index fadb38469c923..da91a237cc701 100644
--- a/xbmc/cores/VideoPlayer/VideoRenderers/LinuxRendererGLES.cpp
+++ b/xbmc/cores/VideoPlayer/VideoRenderers/LinuxRendererGLES.cpp
@@ -2268,6 +2268,17 @@ void CLinuxRendererGLES::CheckVideoParameters(int index)
   if (toneMap != m_toneMap || toneMapMethod != m_toneMapMethod)
   {
     m_reloadShaders = true;
+
+    //! @todo HACK for #28468; clean up properly in Piers beta 2
+    if (toneMap != m_toneMap)
+    {
+      VideoPicture tmp{};
+      tmp.color_space = toneMap ? AVCOL_SPC_UNSPECIFIED : buf.m_srcColSpace;
+      tmp.iWidth = m_sourceWidth;
+      tmp.iHeight = m_sourceHeight;
+      CServiceBroker::GetWinSystem()->SetColorimetry(&tmp);
+    }
+
     m_toneMap = toneMap;
     m_toneMapMethod = toneMapMethod;
   }
