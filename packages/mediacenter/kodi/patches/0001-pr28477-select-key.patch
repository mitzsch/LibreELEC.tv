From e80bc6a1c792457f4f4a1ab8eeee05fe7563ff4b Mon Sep 17 00:00:00 2001
From: Matthias Reichl <hias@horus.com>
Date: Sun, 21 Jun 2026 13:29:48 +0200
Subject: [PATCH 1/7] input/keyboard: add select key

Signed-off-by: Matthias Reichl <hias@horus.com>
---
 xbmc/input/keyboard/XBMC_keysym.h     | 1 +
 xbmc/input/keyboard/XBMC_keytable.cpp | 3 ++-
 xbmc/input/keyboard/XBMC_vkeys.h      | 1 +
 3 files changed, 4 insertions(+), 1 deletion(-)

diff --git a/xbmc/input/keyboard/XBMC_keysym.h b/xbmc/input/keyboard/XBMC_keysym.h
index 11b1ed5c99f8b..ebea35a921d2f 100644
--- a/xbmc/input/keyboard/XBMC_keysym.h
+++ b/xbmc/input/keyboard/XBMC_keysym.h
@@ -290,6 +290,7 @@ enum XBMCKey
   XBMCK_LANGUAGE = 502,
   XBMCK_CHANNEL_UP = 503,
   XBMCK_CHANNEL_DOWN = 504,
+  XBMCK_SELECT = 505,
 
   /*
    * Extended keypad key symbols for Num Lock state-specific behaviors
diff --git a/xbmc/input/keyboard/XBMC_keytable.cpp b/xbmc/input/keyboard/XBMC_keytable.cpp
index d72d402b3702d..d4550a4ac12ab 100644
--- a/xbmc/input/keyboard/XBMC_keytable.cpp
+++ b/xbmc/input/keyboard/XBMC_keytable.cpp
@@ -197,7 +197,8 @@ static const XBMCKEYTABLE XBMCKeyTable[] = {
     {XBMCK_OK, 0, 0, XBMCVK_OK, "ok"},
     {XBMCK_LANGUAGE, 0, 0, XBMCVK_LANGUAGE, "language"},
     {XBMCK_CHANNEL_UP, 0, 0, XBMCVK_CHANNEL_UP, "channel_up"},
-    {XBMCK_CHANNEL_DOWN, 0, 0, XBMCVK_CHANNEL_DOWN, "channel_down"}
+    {XBMCK_CHANNEL_DOWN, 0, 0, XBMCVK_CHANNEL_DOWN, "channel_down"},
+    {XBMCK_SELECT, 0, 0, XBMCVK_SELECT, "select"}
 
     // Function keys
     ,
diff --git a/xbmc/input/keyboard/XBMC_vkeys.h b/xbmc/input/keyboard/XBMC_vkeys.h
index 5f1df4094a4fe..b069bdbc60fa6 100644
--- a/xbmc/input/keyboard/XBMC_vkeys.h
+++ b/xbmc/input/keyboard/XBMC_vkeys.h
@@ -218,6 +218,7 @@ typedef enum
   XBMCVK_LANGUAGE = 0xEF,
   XBMCVK_CHANNEL_UP = 0xF0,
   XBMCVK_CHANNEL_DOWN = 0xF1,
+  XBMCVK_SELECT = 0xF2,
 
   XBMCVK_LAST = 0x3FF
 } XBMCVKey;

From b35e827e3c6918fab6a730ae65f18796a36d1aea Mon Sep 17 00:00:00 2001
From: Matthias Reichl <hias@horus.com>
Date: Sun, 21 Jun 2026 13:38:22 +0200
Subject: [PATCH 2/7] keymaps/keyboard.xml: map select key to Select action

Signed-off-by: Matthias Reichl <hias@horus.com>
---
 system/keymaps/keyboard.xml | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/system/keymaps/keyboard.xml b/system/keymaps/keyboard.xml
index 8c901f0248679..16167ac9da125 100644
--- a/system/keymaps/keyboard.xml
+++ b/system/keymaps/keyboard.xml
@@ -50,6 +50,8 @@
       <ok>Select</ok>
       <ok mod="longpress">ContextMenu</ok>
       <ok mod="ctrl">Enter</ok>
+      <select>Select</select>
+      <select mod="longpress">ContextMenu</select>
       <backspace>Back</backspace>
       <browser_back>Back</browser_back>
       <browser_back mod="longpress">ActivateWindow(Home)</browser_back>

