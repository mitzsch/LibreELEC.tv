+/* bit[15:8]  small_sec_wr_ptr */
+/* bit[7:2]   reserved*/
+/* bit[1] small_sec_wr_ptr_wr_enable*/
+/* bit[0] small_section_enable*/
+#define DEMUX_SMALL_SEC_CTL (STB_CBUS_BASE + DEMUX_1_OFFSET + 0x4c) /* 0x164c*/
