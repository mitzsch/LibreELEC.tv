+
+		if ((pcrpid >= 0) && (pcrpid < 0x1FFF)) {
+			dmx->pcr_chan = dmx_alloc_chan(dmx, DMX_TYPE_TS,
+						       DMX_PES_PCR, pcrpid);
+			if (dmx->pcr_chan == -1)
+				ret = -1;
+		}
+	}
+
+	spin_unlock_irqrestore(&dvb->slock, flags);
+
+	return ret;
+}
+
+static int aml_tsdemux_set_skipbyte(int skipbyte)
+{
+	struct aml_dvb *dvb = &aml_dvb_device;
