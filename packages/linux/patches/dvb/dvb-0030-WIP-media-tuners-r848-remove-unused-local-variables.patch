@@ -764,8 +760,6 @@ static R848_ErrCode R848_PLL(struct r848_priv *priv, u32 LO_Freq,
 
 	u8 R848_XtalDiv = XTAL_DIV2;
 
-	I2C_TYPE R848_I2C;
